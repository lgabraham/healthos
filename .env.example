# ---------------------------------------------------------------------------
# HealthOS environment configuration
# Copy to .env and fill in. Never commit the real .env.
#
# NOTE: keep comments on their OWN lines. An inline comment after an *empty*
# value (e.g. `KEY=   # note`) gets read as the literal value by the .env parser.
# ---------------------------------------------------------------------------

# Database
DATABASE_URL=postgresql+psycopg://healthos:healthos@localhost:5432/healthos

# Whoop
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/auth/whoop/callback
# Filled in automatically after the first OAuth flow; leave blank.
WHOOP_ACCESS_TOKEN=
WHOOP_REFRESH_TOKEN=

# Garmin (via garth). garth handles the session internally from email/password.
GARMIN_EMAIL=
GARMIN_PASSWORD=
# Optional: path to a saved garth session dir. Leave blank to log in fresh.
GARMIN_TOKENSTORE=

# Eight Sleep
EIGHT_SLEEP_EMAIL=
EIGHT_SLEEP_PASSWORD=
# Optional: override the mobile app's public OAuth client (only if rotated).
EIGHT_SLEEP_CLIENT_ID=
EIGHT_SLEEP_CLIENT_SECRET=

# Harvia sauna (MyHarvia cloud). Your MyHarvia app login. Endpoints + Cognito
# config are auto-discovered; region/base/client-id rarely need overriding.
# Leave email/password blank to disable the source (clean no-op).
HARVIA_EMAIL=
HARVIA_PASSWORD=
HARVIA_REGION=eu-west-1
# Optional: pin the Cognito app client id (normally auto-discovered).
HARVIA_COGNITO_CLIENT_ID=
HARVIA_ENDPOINT_BASE=https://prod.myharvia-cloud.net
# `healthos harvia-monitor` polls the stove on/off state this often (seconds).
HARVIA_POLL_SECONDS=60
# Optional: where the monitor persists an in-progress session for restart
# safety. Defaults next to .env; only set to relocate it.
HARVIA_STATE_FILE=

# Auth: a single shared secret that gates the whole API + dashboard. When set,
# the dashboard prompts for this password once per device (cookie session) and
# the API/webhooks/iOS Shortcut accept it as `Authorization: Bearer <token>`,
# an `X-API-Key` header, or a `?token=` query param. STRONGLY recommended for
# any public (e.g. Railway) deploy. Leave blank ONLY for local dev — the app
# logs a loud warning at startup when it's unset. Generate one with e.g.
# `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
HEALTHOS_AUTH_TOKEN=

# App
TIMEZONE=America/Los_Angeles
# Local time to run the nightly sync via the in-process scheduler (24h clock).
SYNC_HOUR=7
SYNC_MINUTE=30
PORT=8000
# Set false when an external cron runs `healthos sync` (avoids double-syncing).
ENABLE_SCHEDULER=true

# Comma-separated origins allowed to call the API (the dashboard).
CORS_ORIGINS=http://localhost:5173

# Calendar context (optional): comma-separated *secret* .ics URLs.
# In Google Calendar: Settings -> [your calendar] -> "Secret address in iCal
# format". Titles are stored locally but redacted from the MCP/Claude layer.
CALENDAR_ICS_URLS=
# Local hour (0-23) at/after which an event counts as "evening".
EVENING_HOUR=18
# Events/day above which a day is flagged calendar_heavy_day.
CALENDAR_HEAVY_THRESHOLD=6
